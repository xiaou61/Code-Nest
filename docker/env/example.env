# Code-Nest 容器运行示例环境变量

SPRING_PROFILES_ACTIVE=docker

XIAOU_MYSQL_URL=jdbc:mysql://mysql:3306/code_nest?serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=utf-8
XIAOU_MYSQL_USERNAME=root
XIAOU_MYSQL_PASSWORD=123456

XIAOU_REDIS_ADDRESS=redis://redis:6379
XIAOU_REDIS_DATABASE=3
XIAOU_SA_TOKEN_REDIS_HOST=redis
XIAOU_SA_TOKEN_REDIS_PORT=6379
XIAOU_SA_TOKEN_REDIS_DATABASE=4

XIAOU_AI_PROVIDER=openai-compatible
XIAOU_AI_BASE_URL=https://your-openai-proxy.example.com/v1
XIAOU_AI_API_KEY=sk-xxxx
XIAOU_AI_CHAT_MODEL=gpt-5.4
XIAOU_AI_RAG_ENABLED=true
XIAOU_AI_RAG_ENDPOINT=http://llamaindex-service:18080
XIAOU_AI_RAG_API_KEY=rag-local-key
