<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaou.plan.mapper.GrowthAutopilotEventMapper">

    <resultMap id="BaseResultMap" type="com.xiaou.plan.domain.GrowthAutopilotEvent">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="goal_id" property="goalId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="event_type" property="eventType" jdbcType="VARCHAR"/>
        <result column="event_detail" property="eventDetail" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO growth_autopilot_event (
            goal_id, user_id, event_type, event_detail, create_time
        ) VALUES (
            #{goalId}, #{userId}, #{eventType}, #{eventDetail}, NOW()
        )
    </insert>

    <select id="selectLatestByGoalId" resultMap="BaseResultMap">
        SELECT id, goal_id, user_id, event_type, event_detail, create_time
        FROM growth_autopilot_event
        WHERE goal_id = #{goalId}
        ORDER BY id DESC
        LIMIT #{limit}
    </select>

</mapper>

