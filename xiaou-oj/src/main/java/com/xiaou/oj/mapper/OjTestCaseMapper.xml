<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaou.oj.mapper.OjTestCaseMapper">

    <resultMap id="BaseResultMap" type="com.xiaou.oj.domain.OjTestCase">
        <id column="id" property="id"/>
        <result column="problem_id" property="problemId"/>
        <result column="input" property="input"/>
        <result column="expected_output" property="expectedOutput"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="is_sample" property="isSample"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO oj_test_case (problem_id, input, expected_output, sort_order, is_sample)
        VALUES (#{problemId}, #{input}, #{expectedOutput}, #{sortOrder}, #{isSample})
    </insert>

    <update id="updateById">
        UPDATE oj_test_case
        <set>
            <if test="input != null">input = #{input},</if>
            <if test="expectedOutput != null">expected_output = #{expectedOutput},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="isSample != null">is_sample = #{isSample},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM oj_test_case WHERE id = #{id}
    </delete>

    <delete id="deleteByProblemId">
        DELETE FROM oj_test_case WHERE problem_id = #{problemId}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM oj_test_case WHERE id = #{id}
    </select>

    <select id="selectByProblemId" resultMap="BaseResultMap">
        SELECT * FROM oj_test_case WHERE problem_id = #{problemId} ORDER BY sort_order
    </select>

    <select id="countByProblemId" resultType="int">
        SELECT COUNT(*) FROM oj_test_case WHERE problem_id = #{problemId}
    </select>

    <select id="selectSampleByProblemId" resultMap="BaseResultMap">
        SELECT * FROM oj_test_case WHERE problem_id = #{problemId} AND is_sample = 1 ORDER BY sort_order
    </select>
</mapper>
