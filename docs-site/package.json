{
  "name": "code-nest-docs-site",
  "version": "2.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:baseline": "node ./scripts/generate-docs-sync-baseline.mjs",
    "postinstall": "npm run sync:baseline",
