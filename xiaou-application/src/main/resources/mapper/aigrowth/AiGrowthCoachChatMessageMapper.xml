<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaou.aigrowth.mapper.AiGrowthCoachChatMessageMapper">

    <resultMap id="AiGrowthCoachChatMessageResultMap" type="com.xiaou.aigrowth.domain.AiGrowthCoachChatMessage">
        <id property="id" column="id"/>
        <result property="sessionId" column="session_id"/>
        <result property="userId" column="user_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="referenceJson" column="reference_json"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="BaseColumns">
        id, session_id, user_id, role, content, reference_json, status, create_time
    </sql>

    <select id="selectBySessionId" resultMap="AiGrowthCoachChatMessageResultMap">
        select <include refid="BaseColumns"/>
        from ai_growth_coach_chat_message
        where session_id = #{sessionId}
        order by id asc
    </select>

    <insert id="insert" parameterType="com.xiaou.aigrowth.domain.AiGrowthCoachChatMessage" useGeneratedKeys="true" keyProperty="id">
        insert into ai_growth_coach_chat_message (
            session_id, user_id, role, content, reference_json, status
        ) values (
            #{sessionId}, #{userId}, #{role}, #{content}, #{referenceJson}, #{status}
        )
    </insert>

    <select id="countAll" resultType="long">
        select count(1) from ai_growth_coach_chat_message
    </select>
</mapper>
