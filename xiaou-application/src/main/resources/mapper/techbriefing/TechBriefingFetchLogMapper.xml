<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaou.techbriefing.mapper.TechBriefingFetchLogMapper">

    <resultMap id="TechBriefingFetchLogResultMap" type="com.xiaou.techbriefing.domain.TechBriefingFetchLog">
        <id property="id" column="id"/>
        <result property="sourceId" column="source_id"/>
        <result property="taskType" column="task_type"/>
        <result property="successCount" column="success_count"/>
        <result property="failCount" column="fail_count"/>
        <result property="status" column="status"/>
        <result property="message" column="message"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.xiaou.techbriefing.domain.TechBriefingFetchLog" useGeneratedKeys="true" keyProperty="id">
        insert into tech_briefing_fetch_log (
            source_id, task_type, success_count, fail_count, status, message, start_time, end_time
        ) values (
            #{sourceId}, #{taskType}, #{successCount}, #{failCount}, #{status}, #{message}, #{startTime}, #{endTime}
        )
    </insert>

    <select id="selectLatest" resultMap="TechBriefingFetchLogResultMap">
        select id, source_id, task_type, success_count, fail_count, status, message, start_time, end_time, create_time
        from tech_briefing_fetch_log
        order by create_time desc, id desc
        limit #{limit}
    </select>
</mapper>
